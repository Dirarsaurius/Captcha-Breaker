# import libraries and extract dataset
import random
from sklearn.metrics import confusion_matrix
import seaborn as sns
import matplotlib.pyplot as plt
import pickle
from tensorflow.keras.callbacks import Callback, EarlyStopping
import time
from tensorflow.keras import layers, models
from sklearn.model_selection import train_test_split
import tensorflow as tf
from PIL import Image
import numpy as np
import shutil
from PIL import Image, UnidentifiedImageError
import zipfile
import os
from pathlib import Path

# zip files
zip_paths = [
    "captcha_4k.zip",
    "CaptchaColored3.zip",
    "archive (11).zip"
]

extract_path = "combined_samples"
os.makedirs(extract_path, exist_ok=True)

# extract files
for zp in zip_paths:
    if os.path.exists(zp):
        with zipfile.ZipFile(zp, 'r') as z:
            z.extractall(extract_path)
        print(f"Extracted {zp}")
    else:
        print(f"{zp} not found")

# collect all png images
all_pngs = list(Path(extract_path).rglob("*.png"))

print("Total images:", len(all_pngs))
print("First few files:", all_pngs[:5])

# # convert images to grayscale to reduce complexity

src_root = Path("combined_samples")
dst_root = Path("combined_gray")

if dst_root.exists():
    shutil.rmtree(dst_root)

dst_root.mkdir(parents=True, exist_ok=True)

png_paths = list(src_root.rglob("*.png"))
print("Converting", len(png_paths), "images...")

processed_count = 0
skipped_count = 0
for src in png_paths:
    rel = src.relative_to(src_root)
    dst = dst_root / rel
    dst.parent.mkdir(parents=True, exist_ok=True)

    try:
        with Image.open(src) as im:
            im = im.convert("RGB")
            gray = im.convert("L")
            gray.save(dst)
        processed_count += 1
    except UnidentifiedImageError:
        print(f"Skipping unidentified image file: {src}")
        skipped_count += 1
    except Exception as e:
        print(f"An unexpected error occurred with file {src}: {e}")
        skipped_count += 1

print(
    f"Done. Processed {processed_count} images, skipped {skipped_count} images.")
print("Example files:", list(dst_root.rglob("*.png"))[:5])

# preprocessing helpers

# image size for the model
TARGET_SIZE = (200, 70)


def load_image_as_gray(path, target_size=TARGET_SIZE):
    # load image, convert to grayscale and resize
    with Image.open(path) as im:
        im = im.convert("RGB").convert("L")
        im = im.resize((target_size[0], target_size[1]), Image.LANCZOS)

        arr = np.array(im).astype(np.float32) / 255.0
        arr = np.expand_dims(arr, axis=-1)
        return arr


def preprocess_batch_from_paths(paths):
    # convert list of image paths to array
    imgs = [load_image_as_gray(p) for p in paths]
    return np.stack(imgs, axis=0)


# create tf.data dataset

gray_root = "combined_gray"


def tf_load_and_preprocess(path):
    # read image, convert to grayscale and resize
    path = tf.cast(path, tf.string)
    image_bytes = tf.io.read_file(path)
    image = tf.io.decode_png(image_bytes, channels=3)
    image = tf.image.rgb_to_grayscale(image)
    image = tf.image.resize(image, [TARGET_SIZE[1], TARGET_SIZE[0]])
    image = image / 255.0
    return image


# get all image paths
all_gray_paths = [str(p) for p in Path(gray_root).rglob("*.png")]
print("Total images:", len(all_gray_paths))

# using tf.data for efficient and scalable data loading
path_ds = tf.data.Dataset.from_tensor_slices(all_gray_paths)
img_ds = path_ds.map(lambda p: tf_load_and_preprocess(p),
                     num_parallel_calls=tf.data.AUTOTUNE)

batch_ds = img_ds.batch(32).prefetch(tf.data.AUTOTUNE)

# check one batch
for batch in batch_ds.take(1):
    print("Batch shape:", batch.shape)

# create labels and split data


# get all image paths
all_gray_paths = sorted([str(p) for p in Path(gray_root).rglob("*.png")])

# labels are taken from filenames
labels = [Path(p).stem for p in all_gray_paths]

# get all unique characters
all_chars = sorted(list(set("".join(labels))))
print("Characters:", all_chars)

# mapping char - index
char_to_idx = {ch: i for i, ch in enumerate(all_chars)}
idx_to_char = {i: ch for ch, i in char_to_idx.items()}


def decode_fn(pred):
    char_ids = np.argmax(pred, axis=-1)
    return "".join(idx_to_char[i] for i in char_ids)


max_captcha_length = 5

y = []
for label in labels:
    encoded = [char_to_idx[c] for c in label]
    y.append(encoded)

# train / validation split
train_paths, val_paths, y_train, y_val = train_test_split(
    all_gray_paths, y, test_size=0.2, random_state=42
)

print("Train size:", len(train_paths))
print("Val size:", len(val_paths))

# create tf.data datasets with labels

# training dataset
train_ds = tf.data.Dataset.from_tensor_slices((train_paths, y_train))
train_ds = train_ds.map(lambda p, y: (tf_load_and_preprocess(p), y),
                        num_parallel_calls=tf.data.AUTOTUNE)
train_ds = train_ds.shuffle(1000).batch(32).prefetch(tf.data.AUTOTUNE)

# validation dataset
val_ds = tf.data.Dataset.from_tensor_slices((val_paths, y_val))
val_ds = val_ds.map(lambda p, y: (tf_load_and_preprocess(p), y),
                    num_parallel_calls=tf.data.AUTOTUNE)
val_ds = val_ds.batch(32).prefetch(tf.data.AUTOTUNE)

# data augmentation


data_augmentation = tf.keras.Sequential([
    layers.RandomRotation(0.05),
    layers.RandomZoom(0.1),
    layers.RandomTranslation(0.05, 0.05),
])

print("Data augmentation ready")

# CNN model


num_classes = len(all_chars)
max_captcha_length = 5

model = models.Sequential([
    tf.keras.Input(shape=(TARGET_SIZE[1], TARGET_SIZE[0], 1)),
    data_augmentation,

    layers.Conv2D(32, (5, 5), activation='relu', padding='same'),
    layers.MaxPooling2D((2, 2)),

    layers.Conv2D(48, (3, 3), activation='relu', padding='same'),
    layers.MaxPooling2D((2, 2)),

    layers.Conv2D(64, (3, 3), activation='relu', padding='same'),
    layers.MaxPooling2D((2, 2)),

    layers.Flatten(),
    layers.Dense(256, activation='relu'),
    layers.Dropout(0.25),

    # predict 5 characters
    layers.Dense(max_captcha_length * num_classes),
    layers.Reshape((max_captcha_length, num_classes)),
    layers.Softmax(axis=-1)
])

model.compile(
    optimizer='adam',
    loss='sparse_categorical_crossentropy',
    metrics=['accuracy']
)

model.summary()

# training callbacks


class TimeHistory(Callback):
    def on_epoch_begin(self, epoch, logs=None):
        self.start_time = time.time()

    def on_epoch_end(self, epoch, logs=None):
        print(
            f"Epoch {epoch+1} time: {round(time.time() - self.start_time, 2)}s")


time_callback = TimeHistory()

early_stop = EarlyStopping(
    monitor="val_loss",
    patience=8,
    restore_best_weights=True
)

# training with early stopping to prevent overfitting
history = model.fit(
    train_ds,
    validation_data=val_ds,
    epochs=100,
    callbacks=[early_stop, time_callback],
    verbose=1
)

# save weights
model.save_weights("cnn_weights.weights.h5")
print("Weights saved")

# save training history
with open("cnn_history.pkl", "wb") as f:
    pickle.dump(history.history, f)

print("History saved")


paths = [str(p) for p in Path("combined_gray").rglob("*.png")]

total = 0
correct = 0
times = []

start_time = time.time()

if paths:
    for path in paths:
        t0 = time.time()

        # predict
        x = load_image_as_gray(path)
        x = np.expand_dims(x, axis=0)
        preds = model.predict(x, verbose=0)

        # decode
        decoded = decode_fn(preds[0])

        t1 = time.time()
        times.append(t1 - t0)

        # ground truth
        gt = Path(path).stem

        if decoded == gt:
            correct += 1

        total += 1

# results
total_time = time.time() - start_time

if total > 0:
    time_per_captcha = np.mean(times)
    accuracy = correct / total

    print("Total time:", round(total_time, 2), "seconds")
    print("Time per captcha:", round(time_per_captcha, 4), "seconds")
    print("Accuracy:", round(accuracy * 100, 2), "%")
elif not paths:
    print("No image files found in 'combined_gray' directory. Cannot perform evaluation.")
else:
    print("No images were processed for evaluation (total = 0).")


# plot training accuracy
plt.plot(history.history['accuracy'], label='train')
plt.plot(history.history['val_accuracy'], label='validation')

plt.xlabel("Epoch")
plt.ylabel("Accuracy")
plt.title("Training vs Validation Accuracy")
plt.legend()
plt.show()

plt.figure(figsize=(12, 4))

# accuracy
plt.subplot(1, 2, 1)
plt.plot(history.history['accuracy'], label='Train')
plt.plot(history.history['val_accuracy'], label='Validation')
plt.title("Accuracy")
plt.xlabel("Epoch")
plt.ylabel("Accuracy")
plt.legend()

# loss
plt.subplot(1, 2, 2)
plt.plot(history.history['loss'], label='Train')
plt.plot(history.history['val_loss'], label='Validation')
plt.title("Loss")
plt.xlabel("Epoch")
plt.ylabel("Loss")
plt.legend()

plt.tight_layout()
plt.show()

# confusion matrix (character level)


eval_ds = val_ds

y_true = []
y_pred = []

for images, labels in eval_ds:
    preds = model.predict(images, verbose=0)
    preds = np.argmax(preds, axis=-1)

    y_true.append(labels.numpy())
    y_pred.append(preds)

# combine batches
y_true = np.concatenate(y_true, axis=0)
y_pred = np.concatenate(y_pred, axis=0)

# flatten to character level
y_true_flat = y_true.flatten()
y_pred_flat = y_pred.flatten()

cm = confusion_matrix(
    y_true_flat,
    y_pred_flat,
    labels=range(len(all_chars))
)

plt.figure(figsize=(12, 10))
sns.heatmap(
    cm,
    annot=True,
    fmt="d",
    cmap="Blues",
    xticklabels=all_chars,
    yticklabels=all_chars
)

plt.xlabel("Predicted Character")
plt.ylabel("True Character")
plt.title("Character-Level Confusion Matrix")
plt.xticks(rotation=45)
plt.yticks(rotation=0)
plt.tight_layout()
plt.show()

# prediction helper


def predict_image(model, img_path, decode_fn=None):
    # load and preprocess image
    x = load_image_as_gray(img_path)
    x = np.expand_dims(x, axis=0)

    preds = model.predict(x)

    if decode_fn is not None:
        return decode_fn(preds)

    return preds


# sample images
gray_files = [str(p) for p in Path("combined_gray").rglob("*.png")]
sample = random.sample(gray_files, min(12, len(gray_files)))

