            imgs = batch["image"]
            labs = batch["label"].numpy()
            preds = self.model.predict(imgs, verbose=0)
            preds_idx = np.argmax(preds, axis=-1)

            for i in range(len(labs)):
                gt = "".join(num_to_char(labs[i]).numpy().astype(str))
                pr = "".join(num_to_char(preds_idx[i]).numpy().astype(str))
                for g, p in zip(gt, pr):
                    tot[g] += 1
                    if g != p:
                        err[g] += 1
        epoch_char_errors.append(err)
# -------- Training & Validation Time Logger --------
class EpochTimeLogger(tf.keras.callbacks.Callback):
    def __init__(self, log_path="epoch_timingk55f128v2.csv"):
        super().__init__()
        self.log_path = log_path
        self.rows = []

        # CSV Header
        if not os.path.exists(log_path):
            with open(log_path, "w", newline="") as f:
                writer = csv.writer(f)
                writer.writerow([
                    "epoch",
                    "train_time_sec",
                    "val_time_sec",
                    "total_time_sec"
                ])

    def on_epoch_begin(self, epoch, logs=None):
        self.epoch_start_time = time.time()

    def on_train_batch_begin(self, batch, logs=None):
        if batch == 0:
            self.train_start = time.time()

    def on_test_begin(self, logs=None):
        self.val_start = time.time()

    def on_test_end(self, logs=None):
        self.val_time = time.time() - self.val_start

    def on_epoch_end(self, epoch, logs=None):
        total_time = time.time() - self.epoch_start_time
        train_time = total_time - getattr(self, "val_time", 0.0)

        self.rows.append([
            epoch + 1,
            round(train_time, 3),
            round(getattr(self, "val_time", 0.0), 3),
            round(total_time, 3)
        ])

        with open(self.log_path, "a", newline="") as f:
            writer = csv.writer(f)
            writer.writerow(self.rows[-1])

        print(
            f"⏱ Epoch {epoch + 1}: "
            f"train={train_time:.2f}s | "
            f"val={getattr(self, 'val_time', 0.0):.2f}s | "
            f"total={total_time:.2f}s"
        )

