# -------- CLEAN TARGET (OpenCV) --------
def make_clean_np(img_np):
    gray = cv2.cvtColor(img_np, cv2.COLOR_RGB2GRAY)
    _, th = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    num, labels, stats, _ = cv2.connectedComponentsWithStats(th, 8)
    mask = np.zeros_like(gray)
    for i in range(1, num):
        if stats[i, cv2.CC_STAT_AREA] >= 40:  # keep letters, remove dots
            mask[labels == i] = 255
    out = cv2.bitwise_and(img_np, img_np, mask=mask)
    return out

def clean_tf(img):
    if OPENCV_AVAILABLE:
        def _f(x):
            x8 = (x*255).astype(np.uint8)
            out = make_clean_np(x8)
            return out.astype(np.float32)/255.
        z = tf.numpy_function(_f, [img], tf.float32)
        z.set_shape([IMG_H, IMG_W, 3])
        return z
    else:
        return img  # fallback minimal cleaning

# -------- Label pad --------
def pad_label(s):
    s = s.decode("utf-8")
    if len(s) >= MAX_LABEL_LEN:
        s = s[:MAX_LABEL_LEN]
    else:
        s = s + (" "*(MAX_LABEL_LEN - len(s)))
    return s

# -------- Encode DAE --------
def enc_dae(p, l):
    img = tf.io.read_file(p)
    img = tf.image.decode_png(img, 3)
    img = tf.image.resize(img, [IMG_H, IMG_W])/255.
    clean = clean_tf(img)
    return img, clean

# -------- Encode OCR --------
def enc_ocr(path, lbl):
    # Make sure label is a Tensor
    lbl = tf.convert_to_tensor(lbl, dtype=tf.string)

    # Load + preprocess image
    img = tf.io.read_file(path)
    img = tf.image.decode_png(img, channels=3)
    img = tf.image.resize(img, [IMG_H, IMG_W])
    img = tf.cast(img, tf.float32) / 255.0

    # Convert string → seq of code points
    chars = tf.strings.unicode_split(lbl, "UTF-8")
    label_ids = char_to_num(chars)
    label_ids = tf.cast(label_ids, tf.int32)

    return {"image": img, "label": label_ids}

# -------- Aug OCR --------
def aug(s):
    img = s["image"]
    lbl = s["label"]
    img = tf.image.random_brightness(img, 0.03)
    img = tf.image.random_contrast(img, 0.95, 1.05)
    img = tf.image.pad_to_bounding_box(img, 1,1, IMG_H+2, IMG_W+2)
    img = tf.image.random_crop(img, [IMG_H, IMG_W, 3])
    return {"image": img, "label": lbl}

# -------- Datasets --------
def ds_dae(paths, labels):
    ds = tf.data.Dataset.from_tensor_slices((paths, labels))
    ds = ds.shuffle(len(paths))
    ds = ds.map(enc_dae, num_parallel_calls=tf.data.AUTOTUNE)
    ds = ds.batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)
    return ds

def ds_ocr(paths, labels, augm=False):
    ds = tf.data.Dataset.from_tensor_slices((paths, labels))
    ds = ds.map(lambda p, l: enc_ocr(p, l), num_parallel_calls=tf.data.AUTOTUNE)
    if augm: ds = ds.map(aug, tf.data.AUTOTUNE)
    ds = ds.padded_batch(BATCH_SIZE,
         padded_shapes={"image":[IMG_H,IMG_W,3], "label":[MAX_LABEL_LEN]},
         padding_values={"image":0., "label":tf.constant(0,dtype=tf.int32)})
    ds = ds.prefetch(tf.data.AUTOTUNE)
    return ds

# -------- UNet-SAFE DAE --------
def build_dae():
    inp = layers.Input((IMG_H, IMG_W, 3), name="dae_input")

    # ---------------- Encoder ----------------
    c1 = layers.Conv2D(32, 3, padding="same", activation="relu")(inp)
    p1 = layers.MaxPooling2D((2, 2), padding="same")(c1)         # 25 × 100 × 32

    c2 = layers.Conv2D(64, 3, padding="same", activation="relu")(p1)
    p2 = layers.MaxPooling2D((2, 2), padding="same")(c2)         # 13 × 50  × 64

    c3 = layers.Conv2D(128, 3, padding="same", activation="relu")(p2)
    p3 = layers.MaxPooling2D((2, 2), padding="same")(c3)         # 7 × 25 × 128

    b = layers.Conv2D(256, 3, padding="same", activation="relu")(p3)

    # ---------------- Decoder ----------------
    # 7×25 → 14×50
    u1 = layers.UpSampling2D((2, 2))(b)
    c3r = layers.Lambda(
        lambda t: tf.image.resize(t, (14, 50)),
        output_shape=(14, 50, 128)
    )(c3)
    d1 = layers.Concatenate()([u1, c3r])
    d1 = layers.Conv2D(128, 3, padding="same", activation="relu")(d1)

    # 14×50 → 28×100
    u2 = layers.UpSampling2D((2, 2))(d1)
    c2r = layers.Lambda(
        lambda t: tf.image.resize(t, (28, 100)),
        output_shape=(28, 100, 64)
    )(c2)
    d2 = layers.Concatenate()([u2, c2r])
    d2 = layers.Conv2D(64, 3, padding="same", activation="relu")(d2)

    # 28×100 → 56×200
    u3 = layers.UpSampling2D((2, 2))(d2)
    c1r = layers.Lambda(
        lambda t: tf.image.resize(t, (56, 200)),
        output_shape=(56, 200, 32)
    )(c1)
    d3 = layers.Concatenate()([u3, c1r])
    d3 = layers.Conv2D(32, 3, padding="same", activation="relu")(d3)

    # ---------------- Final reconstruction to 50×200×3 ----------------
    out = layers.Lambda(
        lambda t: tf.image.resize(t, (IMG_H, IMG_W)),
        output_shape=(IMG_H, IMG_W, 32)
    )(d3)

    out = layers.Conv2D(3, 1, padding="same", activation="sigmoid")(out)

    model = keras.Model(inp, out, name="denoising_autoencoder")
    model.compile(optimizer=keras.optimizers.Adam(1e-3), loss="mse")
    return model


def dae_loss(y_true,y_pred):
    mse = tf.reduce_mean(tf.square(y_true-y_pred))
    ssim = tf.reduce_mean(tf.image.ssim(y_true,y_pred,1.0))
    return 0.3*mse + 0.7*(1-ssim)

# -------- Fixed-5 CRNN --------
def build_crnn(vocab):
    inp = layers.Input((IMG_H, IMG_W, 3))

    x = layers.Conv2D(128,(5,5),padding="same",activation="relu")(inp)
    x = layers.MaxPool2D((2,2),padding="same")(x)

    x = layers.Conv2D(128,(5,5),padding="same",activation="relu")(x)
    x = layers.MaxPool2D((2,2),padding="same")(x)

    x = layers.Conv2D(128,(5,5),padding="same",activation="relu",name="enc_bottleneck")(x)

    # 50/4=13, 200/4=50
    h = 13; w = 50; c = 128
    seg_w = w//MAX_LABEL_LEN  # 10
    def split(t):
        b = tf.shape(t)[0]
        t = tf.reshape(t,(b,h,MAX_LABEL_LEN,seg_w,c))
        return tf.reduce_mean(t,axis=[1,3])

    s = layers.Lambda(split)(x)   # (batch,5,c)

    y = layers.Dense(128,activation="relu")(s)
    y = layers.Bidirectional(layers.GRU(64,return_sequences=True))(y)
    out = layers.Dense(vocab+1,activation="softmax")(y)

    return keras.Model(inp,out)

# -------- Weight transfer --------
def transfer(dae,crnn):
    dc = [l for l in dae.layers if isinstance(l, layers.Conv2D)]
    cc = [l for l in crnn.layers if isinstance(l, layers.Conv2D)]
    for i in range(min(len(dc),len(cc))):
        try: cc[i].set_weights(dc[i].get_weights())
        except: pass
    print("Transferred",min(len(dc),len(cc)),"layers")

# -------- Grad-CAM per char --------
def gradcam_char(model,img,pred,layer="enc_bottleneck"):
    gm = keras.Model(model.inputs,
                     [model.get_layer(layer).output, model.output])
    img_t = tf.expand_dims(img,0)
    heatmaps=[]
    for pos in range(MAX_LABEL_LEN):
        cls=int(pred[pos])
        with tf.GradientTape() as tape:
            conv_out,pred_out=gm(img_t)
            score=pred_out[0,pos,cls]
        grads=tape.gradient(score,conv_out)[0]
        w=tf.reduce_mean(grads,axis=(0,1))
        cam=tf.reduce_sum(conv_out[0]*w,axis=-1)
        cam=tf.maximum(cam,0)
        cam=cam/(tf.reduce_max(cam)+1e-8)
        cam=tf.image.resize(cam[...,None],(IMG_H,IMG_W)).numpy().squeeze()
        heatmaps.append(cam)
    return heatmaps

# -------- Save FAILS --------
def save_fails(model,ds,max_n=20):
    count=0
    for batch in ds:
        imgs=batch["image"].numpy()
        labs=batch["label"].numpy()
        preds=model.predict(imgs)
        pred_idx=np.argmax(preds,axis=-1)
        for i in range(len(imgs)):
            gt="".join(num_to_char(labs[i]).numpy().astype(str))
            pr="".join([num_to_char([int(x)]).numpy().astype(str)[0] if x!=0 else "" for x in pred_idx[i]])
            if gt!=pr:
                hm=gradcam_char(model,imgs[i],pred_idx[i])
                fig,ax=plt.subplots(1,MAX_LABEL_LEN+1,figsize=(14,3))
                ax[0].imshow(imgs[i]); ax[0].set_title(f"GT:{gt}\nPR:{pr}"); ax[0].axis("off")
                for j in range(MAX_LABEL_LEN):
                    ax[j+1].imshow(imgs[i])
                    ax[j+1].imshow(hm[j],alpha=0.5,cmap="jet")
                    ax[j+1].axis("off")
                fig.savefig(os.path.join(FAIL_DIR,f"fail_{count}.png"),dpi=160)
                plt.close(fig)
                count+=1
                if count>=max_n:
                    return

