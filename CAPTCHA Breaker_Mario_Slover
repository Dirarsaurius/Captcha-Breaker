# === Hilfsfunktionen ===
def get_random_subset():
    """Zieht zufällig SAMPLE_SIZE Bilder aus allen verfügbaren."""
    total_images = np.array(sorted(list(map(str, list(dir.glob("*.png"))))))
    total_labels = np.array([img.split(os.path.sep)[-1].split(".png")[0] for img in total_images])
    idx = np.random.choice(len(total_images), sample_size, replace=False)
    imgs = total_images[idx]
    labels = total_labels[idx]
    return imgs, labels

def make_dataset(imgs, labels, batch_size=32, augment=False):
    ds = tf.data.Dataset.from_tensor_slices((imgs, labels))
    ds = ds.map(encode_sample, num_parallel_calls=tf.data.AUTOTUNE)

    if augment:
        ds = ds.map(augment_data, num_parallel_calls=tf.data.AUTOTUNE)

    ds = ds.padded_batch(
        batch_size,
        padded_shapes={
            "image": [img_height, img_width, 3],
            "label": [None]
        },
        padding_values={
            "image": tf.constant(0.0, dtype=tf.float32),
            "label": tf.constant(0, dtype=tf.int64)
        },
        drop_remainder=True
    )

    return ds.prefetch(tf.data.AUTOTUNE)


