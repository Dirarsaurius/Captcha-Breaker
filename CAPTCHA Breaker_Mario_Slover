# === Dekodier- und Evaluationsfunktionen ===
def decode_batch_predictions(pred):
    input_len = np.ones(pred.shape[0]) * pred.shape[1]
    results = keras.backend.ctc_decode(pred, input_length=input_len, greedy=True)[0][0]
    output_text = []
    for res in results:
        text = tf.strings.reduce_join(num_to_char(res)).numpy().decode("utf-8")
        output_text.append(text)
    return output_text

def evaluate_model(model, dataset, max_batches=10):
    """Berechnet den Anteil korrekt erkannter Captchas."""
    total = 0
    correct = 0
    for batch in dataset.take(max_batches):
        images = batch["image"]
        labels = batch["label"]
        preds = model.predict(images, verbose=0)
        pred_texts = decode_batch_predictions(preds)
        true_texts = [tf.strings.reduce_join(num_to_char(l)).numpy().decode('utf-8') for l in labels]
        for pt, tt in zip(pred_texts, true_texts):
            total += 1
            if pt == tt:
                correct += 1
    return correct / total if total > 0 else 0.0

# === Automatisches wiederholtes Training mit Evaluation ===
for cycle in range(1, training_cycles + 1):
    print(f"\n===== 🚀 Trainingsrunde {cycle}/{training_cycles} =====")

    imgs, labels = get_random_subset()
    ds_train = make_dataset(imgs, labels, batch_size, augment=True)
    ds_val   = make_dataset(imgs, labels, batch_size, augment=False)

    history = model.fit(
        ds_train,
        validation_data=ds_val,
        epochs=EPOCHS,
        callbacks=callbacks,
        verbose=1
    )

    acc = evaluate_model(model, ds_val, max_batches=8)
    print(f"📈 Accuracy nach Runde {cycle}: {acc * 100:.2f}%")

