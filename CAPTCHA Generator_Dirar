        "    total, ok = 0, 0\n",
        "    for p, gt in zip(preds, gts):\n",
        "        m = max(len(p), len(gt))\n",
        "        total += m\n",
        "        for i in range(m):\n",
        "            pc = p[i] if i < len(p) else None\n",
        "            gc = gt[i] if i < len(gt) else None\n",
        "            ok += int(pc == gc)\n",
        "    return ok / max(1, total)\n"
