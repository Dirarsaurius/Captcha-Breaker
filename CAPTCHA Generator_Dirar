        "# =========================\n",
        "# CONTAINER 3/9: Dataset + Collate (CTC)\n",
        "# =========================\n",
        "\n",
        "class CaptchaDataset(Dataset):\n",
        "    def __init__(self, folder: Path):\n",
        "        self.files = sorted(folder.glob(\"*.jpg\"))\n",
        "        if len(self.files) == 0:\n",
        "            raise RuntimeError(f\"Keine Bilder in {folder} gefunden.\")\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.files)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        p = self.files[idx]\n",
        "        gt = p.stem.split(\"_\")[0]  # \"abcd_000123\" -> \"abcd\"\n",
        "\n",
        "        img_bgr = cv2.imread(str(p), cv2.IMREAD_COLOR)\n",
        "        if img_bgr is None:\n",
        "            raise RuntimeError(f\"Konnte Bild nicht lesen: {p}\")\n",
        "\n",
        "        gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)\n",
        "        gray = cv2.resize(gray, (IMG_W, IMG_H), interpolation=cv2.INTER_AREA)\n",
        "\n",
        "        x = gray.astype(np.float32) / 255.0\n",
        "        x = torch.from_numpy(x).unsqueeze(0)  # [1,H,W]\n",
        "\n",
        "        y = torch.tensor([C2I[c] for c in gt], dtype=torch.long)\n",
        "        return x, y, gt, p.name\n",
        "\n",
        "def collate_ctc(batch):\n",
        "    xs, ys, gts, fnames = zip(*batch)\n",
        "    xs = torch.stack(xs, dim=0)                # [B,1,H,W]\n",
        "    y_lens = torch.tensor([len(y) for y in ys], dtype=torch.long)\n",
        "    ys_cat = torch.cat(ys, dim=0)              # [sumL]\n",
        "    return xs, ys_cat, y_lens, list(gts), list(fnames)\n",
        "\n",
        "train_ds = CaptchaDataset(TRAIN_DIR)\n",
        "val_ds   = CaptchaDataset(VAL_DIR)\n",
        "\n",
        "train_loader = DataLoader(\n",
        "    train_ds, batch_size=BATCH_SIZE, shuffle=True,\n",
        "    num_workers=NUM_WORKERS, pin_memory=True, collate_fn=collate_ctc\n",
        ")\n",
        "val_loader = DataLoader(\n",
        "    val_ds, batch_size=BATCH_SIZE, shuffle=False,\n",
        "    num_workers=NUM_WORKERS, pin_memory=True, collate_fn=collate_ctc\n",
        ")\n",
        "\n",
        "print(\"Train:\", len(train_ds), \"Val:\", len(val_ds))\n"
