        "            print(f\"  {i+1}/{n}\")\n",
        "\n",
        "write_dataset(TRAIN_DIR, N_TRAIN, force=REGENERATE_DATASET)\n",
        "write_dataset(VAL_DIR, N_VAL, force=REGENERATE_DATASET)\n"
