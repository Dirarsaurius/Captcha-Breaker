        "# =========================\n",
        "# CONTAINER 5/9: Decoding + Accuracy (Exact + Char)\n",
        "# =========================\n",
        "\n",
        "def decode_greedy(logits_TBC: torch.Tensor):\n",
        "    \"\"\"\n",
        "    logits_TBC: [T,B,C]\n",
        "    Greedy decode, dann:\n",
        "    - repeats zusammenfassen\n",
        "    - blanks entfernen\n",
        "    \"\"\"\n",
        "    probs = logits_TBC.softmax(dim=2)\n",
        "    best = probs.argmax(dim=2)  # [T,B]\n",
        "    best = best.detach().cpu().numpy()\n",
        "\n",
        "    out = []\n",
        "    T, B = best.shape\n",
        "    for b in range(B):\n",
        "        seq = best[:, b].tolist()\n",
        "\n",
        "        collapsed = []\n",
        "        prev = None\n",
        "        for s in seq:\n",
        "            if s != prev:\n",
        "                collapsed.append(s)\n",
        "            prev = s\n",
        "\n",
        "        collapsed = [s for s in collapsed if s != 0]  # remove blank\n",
        "        txt = \"\".join(I2C[s] for s in collapsed if s in I2C)\n",
        "        out.append(txt)\n",
        "    return out\n",
