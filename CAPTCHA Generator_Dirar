        "# =========================\n",
        "# CONTAINER 4/9 (NEU): CRNN stabiler gegen CTC-Collapse\n",
        "# - weniger Timesteps (W) durch stärkeres Downsampling\n",
        "# - H am Ende sicher = 1\n",
        "# =========================\n",
        "\n",
        "class CRNN(nn.Module):\n",
        "    def __init__(self, num_classes=len(VOCAB)):\n",
        "        super().__init__()\n",
        "\n",
        "        # Input: [B, 1, 32, 160]\n",
        "        self.cnn = nn.Sequential(\n",
        "            # 32x160 -> 16x80\n",
        "            nn.Conv2d(1, 64, 3, padding=1),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # 16x80 -> 8x40\n",
        "            nn.Conv2d(64, 128, 3, padding=1),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # 8x40 -> 4x20   (W halbiert: wichtig!)\n",
        "            nn.Conv2d(128, 256, 3, padding=1),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # 4x20 -> 2x20\n",
        "            nn.Conv2d(256, 512, 3, padding=1),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.BatchNorm2d(512),\n",
        "            nn.MaxPool2d((2, 1)),\n",
        "\n",
        "            # 2x20 -> 1x19  (Kernel 2 reduziert H von 2 auf 1)\n",
        "            nn.Conv2d(512, 512, 2, stride=1, padding=0),\n",
        "            nn.ReLU(inplace=True),\n",
        "            nn.BatchNorm2d(512),\n",
        "        )\n",
        "\n",
        "        # Nach CNN: [B, 512, 1, W'] -> Sequenz [B, W', 512]\n",
        "        self.rnn = nn.LSTM(\n",
        "            input_size=512,\n",
        "            hidden_size=256,\n",
        "            num_layers=2,\n",
        "            bidirectional=True,\n",
        "            batch_first=True\n",
        "        )\n",
        "        self.fc = nn.Linear(256 * 2, num_classes)  # biLSTM\n",
        "\n",
        "    def forward(self, x):\n",
        "        # x: [B,1,32,160]\n",
        "        feat = self.cnn(x)  # [B,512,1,W']\n",
        "        b, c, h, w = feat.shape\n",
        "\n",
        "        if h != 1:\n",
        "            raise RuntimeError(f\"CNN-Output Höhe ist {h}, erwartet 1. (Check Pooling/IMG_H)\")\n",
        "\n",
        "        feat = feat.squeeze(2)         # [B,512,W']\n",
        "        feat = feat.permute(0, 2, 1)   # [B,W',512]  (time-major im Batch)\n",
        "\n",
        "        seq, _ = self.rnn(feat)        # [B,W',512]\n",
        "        logits = self.fc(seq)          # [B,W',classes]\n",
        "\n",
        "        # CTC erwartet [T,B,C]\n",
        "        return logits.permute(1, 0, 2)\n",
        "\n",
        "\n",
        "# Modell + Loss + Optimizer (wie gehabt)\n",
        "model = CRNN(num_classes=len(VOCAB)).to(device)\n",
        "\n",
        "criterion = nn.CTCLoss(blank=0, zero_infinity=True)\n",
        "optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)\n",
        "\n",
        "print(\"Model ready. Example output shape check:\")\n",
        "with torch.no_grad():\n",
        "    dummy = torch.randn(2, 1, IMG_H, IMG_W, device=device)\n",
        "    out = model(dummy)\n",
        "    print(\"logits [T,B,C] =\", tuple(out.shape))\n"
