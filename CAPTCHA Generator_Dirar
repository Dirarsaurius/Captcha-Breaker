        "# =========================\n",
        "# CONTAINER 2/9 (NEU): Generator mit DIFFICULTY (0.0 = easy, 1.0 = hard)\n",
        "# =========================\n",
        "\n",
        "DIFFICULTY = 0.25          # <- 0.2 bis 0.35 ist meistens gut zum Start\n",
        "REGENERATE_DATASET = True  # <- einmal True, danach wieder False\n",
        "\n",
        "def _pick_font(font_size: int):\n",
        "    candidates = [\n",
        "        \"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\",\n",
        "        \"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\",\n",
        "        \"/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf\",\n",
        "    ]\n",
        "    for p in candidates:\n",
        "        if os.path.exists(p):\n",
        "            try:\n",
        "                return ImageFont.truetype(p, font_size)\n",
        "            except:\n",
        "                pass\n",
        "    return ImageFont.load_default()\n",
        "\n",
        "def random_text(n=CAPTCHA_LEN):\n",
        "    return \"\".join(random.choice(CHARS) for _ in range(n))\n",
        "\n",
        "def _lerp(a, b, t):\n",
        "    return a + (b - a) * float(t)\n",
        "\n",
        "def generate_captcha_image(text: str, w=IMG_W, h=IMG_H, d=DIFFICULTY) -> Image.Image:\n",
        "    \"\"\"\n",
        "    Difficulty d in [0,1]\n",
        "    d=0: fast clean\n",
        "    d=1: heavy noise/lines/warp/blur\n",
        "    \"\"\"\n",
        "    d = float(np.clip(d, 0.0, 1.0))\n",
        "\n",
        "    # Hintergrund: fast weiß, nur leichtes Noise je nach d\n",
        "    base = Image.new(\"RGB\", (w, h), (255, 255, 255))\n",
        "    bg_noise_sigma = _lerp(2.0, 10.0, d)  # früher hattest du ~12, das ist brutal\n",
        "    noise = np.random.normal(0.0, bg_noise_sigma, size=(h, w, 3)).astype(np.int16)\n",
        "    bg = np.clip(np.array(base).astype(np.int16) + noise, 0, 255).astype(np.uint8)\n",
        "    base = Image.fromarray(bg, mode=\"RGB\")\n",
        "    draw = ImageDraw.Draw(base)\n",
        "\n",
        "    # Linien: am Anfang wenige + dünn\n",
        "    n_lines = int(round(_lerp(0, 4, d)))\n",
        "    for _ in range(n_lines):\n",
        "        x1, y1 = random.randint(0, w), random.randint(0, h)\n",
        "        x2, y2 = random.randint(0, w), random.randint(0, h)\n",
        "        col = tuple(int(x) for x in np.random.randint(30, 140, size=3))  # nicht zu dunkel\n",
        "        draw.line((x1, y1, x2, y2), fill=col, width=1)\n",
        "\n",
        "    # Bögen: erst ab mittlerer Difficulty\n",
        "    n_arcs = int(round(_lerp(0, 2, max(0.0, d - 0.2) / 0.8)))\n",
        "    for _ in range(n_arcs):\n",
        "        x0 = random.randint(-10, w-10)\n",
        "        y0 = random.randint(-10, h-10)\n",
        "        x1 = x0 + random.randint(40, 120)\n",
        "        y1 = y0 + random.randint(20, 80)\n",
        "        start = random.randint(0, 180)\n",
        "        end = start + random.randint(60, 220)\n",
        "        col = tuple(int(x) for x in np.random.randint(40, 170, size=3))\n",
        "        draw.arc((x0, y0, x1, y1), start=start, end=end, fill=col, width=1)\n",
        "\n",
        "    # Text: größer, klarer, weniger Rotation am Anfang\n",
        "    font = _pick_font(font_size=int(round(_lerp(26, 22, d))))  # easy: größer\n",
        "    x = random.randint(8, 14)\n",
        "    y = random.randint(0, 6)\n",
        "\n",
        "    max_angle = _lerp(8.0, 22.0, d)   # easy: ±8°, hard: ±22°\n",
        "    jitter_x  = int(round(_lerp(0, 3, d)))\n",
        "    jitter_y  = int(round(_lerp(0, 2, d)))\n",
        "\n",
        "    for ch in text:\n",
        "        ch_img = Image.new(\"RGBA\", (52, 52), (0, 0, 0, 0))\n",
        "        ch_draw = ImageDraw.Draw(ch_img)\n",
        "\n",
        "        # Textfarbe: eher dunkel, aber nicht schwarz\n",
        "        col = tuple(int(v) for v in np.random.randint(0, 60, size=3))\n",
        "        ch_draw.text((random.randint(6, 10), random.randint(6, 12)), ch, font=font, fill=col)\n",
        "\n",
        "        angle = random.uniform(-max_angle, max_angle)\n",
        "        ch_img = ch_img.rotate(angle, resample=Image.BICUBIC, expand=True)\n",
        "\n",
        "        base.paste(\n",
        "            ch_img,\n",
        "            (x + random.randint(-jitter_x, jitter_x), y + random.randint(-jitter_y, jitter_y)),\n",
        "            ch_img\n",
        "        )\n",
        "        x += random.randint(30, 36)\n",
        "\n",
        "    # Affine Warp: erst ab höherer Difficulty, und mild\n",
        "    if d > 0.35:\n",
        "        w_strength = (d - 0.35) / 0.65\n",
        "        a = 1 + random.uniform(-0.03, 0.03) * w_strength\n",
        "        b = random.uniform(-0.06, 0.06) * w_strength\n",
        "        c = random.uniform(-3, 3) * w_strength\n",
        "        d1 = random.uniform(-0.06, 0.06) * w_strength\n",
        "        e = 1 + random.uniform(-0.03, 0.03) * w_strength\n",
        "        f = random.uniform(-2, 2) * w_strength\n",
        "        base = base.transform((w, h), Image.AFFINE, (a, b, c, d1, e, f), resample=Image.BICUBIC)\n",
        "\n",
        "    # Speckles: sehr wenig am Anfang\n",
        "    specks = int(round(_lerp(0, 120, d)))\n",
        "    if specks > 0:\n",
        "        arr = np.array(base)\n",
        "        for _ in range(specks):\n",
        "            xx = random.randint(0, w-1)\n",
        "            yy = random.randint(0, h-1)\n",
        "            arr[yy, xx] = np.random.randint(80, 200, size=3)  # eher hell\n",
        "        base = Image.fromarray(arr)\n",
        "\n",
        "    # Blur: easy fast none\n",
        "    if random.random() < _lerp(0.05, 0.65, d):\n",
        "        base = base.filter(ImageFilter.GaussianBlur(radius=_lerp(0.0, 0.9, d)))\n",
        "\n",
        "    # Kontrast: nur leicht\n",
        "    if random.random() < _lerp(0.1, 0.5, d):\n",
        "        base = ImageEnhance.Contrast(base).enhance(_lerp(1.0, 1.25, d))\n",
        "\n",
        "    return base\n",
        "\n",
        "def maybe_clear_folder(folder: Path):\n",
